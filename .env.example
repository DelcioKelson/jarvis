# Jarvis AI Assistant Configuration
# Copy this file to .env, ~/.config/jarvis/config.env, or ~/.jarvis.env

# ── Required ────────────────────────────────────────────────────────
# Get your free API key at https://console.groq.com/keys
JARVIS_API_KEY=your-api-key-here

# ── Optional ────────────────────────────────────────────────────────
# Base URL — defaults to Groq Cloud
# JARVIS_API_BASE_URL=https://api.groq.com/openai/v1

# Model — see https://console.groq.com/docs/models for the full list
# JARVIS_MODEL=llama-3.3-70b-versatile   # best accuracy (default)
# JARVIS_MODEL=llama-3.1-8b-instant      # fastest / lowest latency

# Request timeout in seconds
# JARVIS_TIMEOUT=30.0

# Debug Mode (set to true or 1 to enable)
# JARVIS_DEBUG=false
