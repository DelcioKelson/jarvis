# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
version: "2.0.0"
synopsis: "AI-powered CLI assistant using any OpenAI-compatible API"
description:
  "Jarvis is a CLI assistant that uses any OpenAI-compatible API to execute commands and answer questions through natural language. Features interactive REPL mode, colored output, and type-safe command execution."
maintainer: ["Jarvis Team"]
authors: ["Jarvis Team"]
license: "MIT"
homepage: "https://github.com/DelcioKelson/jarvis"
bug-reports: "https://github.com/DelcioKelson/jarvis/issues"
depends: [
  "ocaml" {>= "5.0"}
  "dune" {>= "3.10" & >= "3.10"}
  "cohttp-lwt-unix" {>= "5.0"}
  "yojson" {>= "2.0"}
  "bos" {>= "0.2"}
  "lwt" {>= "5.6"}
  "lwt_ssl" {>= "1.2"}
  "verity" {>= "0.1.0"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/DelcioKelson/jarvis.git"
